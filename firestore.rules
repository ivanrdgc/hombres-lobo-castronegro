rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Juego amistoso sin autenticación: acceso abierto pero limitado
    // exclusivamente a la colección de grupos y con tamaño acotado.
    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if request.resource == null
        || request.resource.data.keys().hasOnly(
          ['name', 'createdAt', 'masterId', 'status', 'settings', 'extraRoles', 'game']);
      allow delete: if true;

      match /players/{playerId} {
        allow read, write: if true;
      }
    }
  }
}
